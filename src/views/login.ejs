<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Sistema Roles</title>
    <style><%- bootstrapCSS %></style>
</head>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh; margin: 0; font-family: system-ui, sans-serif;">
    <div class="card shadow" style="width: 380px; border-radius: 8px; border: none;">
        <div class="card-body p-4 bg-white" style="border-radius: 8px;">
            <h2 class="card-title h4 text-center mb-4 text-primary fw-bold">Acesse o Sistema</h2>

            <% if (error) { %>
                <div class="alert alert-danger py-2 text-center small"><%= error %></div>
            <% } %>

            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">E-mail</label>
                    <input class="form-control" type="email" name="email" placeholder="seu@email.com" required style="border-radius: 6px;">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-secondary">Senha</label>
                    <input class="form-control" type="password" name="senha" placeholder="••••••••" required style="border-radius: 6px;">
                </div>
                <button type="submit" class="btn btn-primary w-100 mt-3 py-2 fw-bold" style="border-radius: 6px;">Entrar</button>
            </form>
            <p class="text-center mt-3 mb-0 small text-muted">Não tem conta? <a href="/cadastro" class="text-decoration-none">Cadastre-se aqui</a></p>
        </div>
    </div>
</body>
</html>